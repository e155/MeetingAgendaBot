# ── Telegram Bot ─────────────────────────────────────────────
# Token from @BotFather
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram group ID (negative number)
# To find: write /chatid in the group after starting the bot
GROUP_ID=-1009999999999

# ── Access Control ───────────────────────────────────────────
# Comma-separated Telegram user IDs of bot administrators
# Admins can use /backup, /restore and override organizer role
# To find your user ID: write /start to @userinfobot
ADMIN_IDS=123456789,987654321

# Who can use /backup and /restore:
#   admin — only users listed in ADMIN_IDS
#   all   — any user in private chat with the bot
BACKUP_OPERATOR=admin

# ── PDF Report ───────────────────────────────────────────────
# Title shown in the PDF protocol header
PDF_TITLE=IT Meeting Agenda

# ── Email Report ─────────────────────────────────────────────
# Set SENDMAIL=true to send HTML report + PDF after /summary
SENDMAIL=false

# Local SMTP relay (no authentication required)
SMTP_HOST=192.168.1.10
SMTP_PORT=25
SMTP_FROM=meetingbot@company.local
SMTP_TO=team@company.local,manager@company.local
